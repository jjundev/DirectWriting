<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ime_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/keyboard_background"
    android:paddingBottom="4dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:id="@+id/panel_keyboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="6dp">

            <LinearLayout
                android:id="@+id/keyboard_quickbar_row"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <Button
                    android:id="@+id/key_clipboard_chip"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_quickbar_chip"
                    android:text="@string/key_clipboard_default"
                    android:textAllCaps="false"
                    android:textColor="@color/quickbar_text"
                    android:textSize="14sp"
                    android:singleLine="true"
                    android:ellipsize="end"
                    android:contentDescription="@string/key_clipboard_default" />

                <Button
                    android:id="@+id/btn_mode_toggle"
                    android:layout_width="56dp"
                    android:layout_height="34dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_quickbar_button"
                    android:text="@string/mode_handwriting"
                    android:textAllCaps="false"
                    android:textColor="@color/quickbar_text"
                    android:textSize="13sp"
                    android:contentDescription="@string/btn_mode_toggle" />

                <Button
                    android:id="@+id/key_number_row_toggle"
                    android:layout_width="52dp"
                    android:layout_height="34dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_quickbar_button"
                    android:text="@string/key_number_row_toggle"
                    android:textAllCaps="false"
                    android:textColor="@color/quickbar_text"
                    android:textSize="13sp"
                    android:contentDescription="@string/key_number_row_toggle" />

                <Button
                    android:id="@+id/key_quickbar_close"
                    android:layout_width="52dp"
                    android:layout_height="34dp"
                    android:background="@drawable/bg_quickbar_button"
                    android:text="@string/key_quickbar_close"
                    android:textAllCaps="false"
                    android:textColor="@color/quickbar_text"
                    android:textSize="14sp"
                    android:contentDescription="@string/key_quickbar_close" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/keyboard_number_row"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:orientation="horizontal"
                android:layout_marginBottom="2dp">

                <Button android:id="@+id/key_num_1" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_key" android:text="1" android:tag="1" android:textColor="@color/key_text" android:textSize="17sp" android:textAllCaps="false" />
                <Button android:id="@+id/key_num_2" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_key" android:text="2" android:tag="2" android:textColor="@color/key_text" android:textSize="17sp" android:textAllCaps="false" />
                <Button android:id="@+id/key_num_3" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_key" android:text="3" android:tag="3" android:textColor="@color/key_text" android:textSize="17sp" android:textAllCaps="false" />
                <Button android:id="@+id/key_num_4" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_key" android:text="4" android:tag="4" android:textColor="@color/key_text" android:textSize="17sp" android:textAllCaps="false" />
                <Button android:id="@+id/key_num_5" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_key" android:text="5" android:tag="5" android:textColor="@color/key_text" android:textSize="17sp" android:textAllCaps="false" />
                <View
                    android:id="@+id/keyboard_number_row_split_gap"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:visibility="gone" />
                <Button android:id="@+id/key_num_6" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_key" android:text="6" android:tag="6" android:textColor="@color/key_text" android:textSize="17sp" android:textAllCaps="false" />
                <Button android:id="@+id/key_num_7" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_key" android:text="7" android:tag="7" android:textColor="@color/key_text" android:textSize="17sp" android:textAllCaps="false" />
                <Button android:id="@+id/key_num_8" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_key" android:text="8" android:tag="8" android:textColor="@color/key_text" android:textSize="17sp" android:textAllCaps="false" />
                <Button android:id="@+id/key_num_9" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_key" android:text="9" android:tag="9" android:textColor="@color/key_text" android:textSize="17sp" android:textAllCaps="false" />
                <Button android:id="@+id/key_num_0" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_key" android:text="0" android:tag="0" android:textColor="@color/key_text" android:textSize="17sp" android:textAllCaps="false" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/keyboard_row_1"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:orientation="horizontal">

                <Button android:id="@+id/key_q" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_key" android:text="q" android:textColor="@color/key_text" android:textSize="18sp" android:textAllCaps="false" />
                <Button android:id="@+id/key_w" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_key" android:text="w" android:textColor="@color/key_text" android:textSize="18sp" android:textAllCaps="false" />
                <Button android:id="@+id/key_e" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_key" android:text="e" android:textColor="@color/key_text" android:textSize="18sp" android:textAllCaps="false" />
                <Button android:id="@+id/key_r" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_key" android:text="r" android:textColor="@color/key_text" android:textSize="18sp" android:textAllCaps="false" />
                <Button android:id="@+id/key_t" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_key" android:text="t" android:textColor="@color/key_text" android:textSize="18sp" android:textAllCaps="false" />
                <View
                    android:id="@+id/keyboard_row_1_split_gap"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:visibility="gone" />
                <Button android:id="@+id/key_y" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_key" android:text="y" android:textColor="@color/key_text" android:textSize="18sp" android:textAllCaps="false" />
                <Button android:id="@+id/key_u" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_key" android:text="u" android:textColor="@color/key_text" android:textSize="18sp" android:textAllCaps="false" />
                <Button android:id="@+id/key_i" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_key" android:text="i" android:textColor="@color/key_text" android:textSize="18sp" android:textAllCaps="false" />
                <Button android:id="@+id/key_o" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_key" android:text="o" android:textColor="@color/key_text" android:textSize="18sp" android:textAllCaps="false" />
                <Button android:id="@+id/key_p" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_key" android:text="p" android:textColor="@color/key_text" android:textSize="18sp" android:textAllCaps="false" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/keyboard_row_2"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <Button android:id="@+id/key_a" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_key" android:text="a" android:textColor="@color/key_text" android:textSize="18sp" android:textAllCaps="false" />
                <Button android:id="@+id/key_s" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_key" android:text="s" android:textColor="@color/key_text" android:textSize="18sp" android:textAllCaps="false" />
                <Button android:id="@+id/key_d" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_key" android:text="d" android:textColor="@color/key_text" android:textSize="18sp" android:textAllCaps="false" />
                <Button android:id="@+id/key_f" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_key" android:text="f" android:textColor="@color/key_text" android:textSize="18sp" android:textAllCaps="false" />
                <Button android:id="@+id/key_g" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_key" android:text="g" android:textColor="@color/key_text" android:textSize="18sp" android:textAllCaps="false" />
                <View
                    android:id="@+id/keyboard_row_2_split_gap"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:visibility="gone" />
                <Button android:id="@+id/key_h" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_key" android:text="h" android:textColor="@color/key_text" android:textSize="18sp" android:textAllCaps="false" />
                <Button android:id="@+id/key_j" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_key" android:text="j" android:textColor="@color/key_text" android:textSize="18sp" android:textAllCaps="false" />
                <Button android:id="@+id/key_k" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_key" android:text="k" android:textColor="@color/key_text" android:textSize="18sp" android:textAllCaps="false" />
                <Button android:id="@+id/key_l" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_key" android:text="l" android:textColor="@color/key_text" android:textSize="18sp" android:textAllCaps="false" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/keyboard_row_3"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/key_shift"
                    android:layout_width="62dp"
                    android:layout_height="match_parent"
                    android:layout_margin="2dp"
                    android:background="@drawable/bg_key_special"
                    android:text="@string/key_shift_off"
                    android:textAllCaps="false"
                    android:textColor="@color/key_text"
                    android:textSize="16sp"
                    android:contentDescription="@string/key_shift_off" />

                <Button android:id="@+id/key_z" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_key" android:text="z" android:textColor="@color/key_text" android:textSize="18sp" android:textAllCaps="false" />
                <Button android:id="@+id/key_x" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_key" android:text="x" android:textColor="@color/key_text" android:textSize="18sp" android:textAllCaps="false" />
                <Button android:id="@+id/key_c" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_key" android:text="c" android:textColor="@color/key_text" android:textSize="18sp" android:textAllCaps="false" />
                <Button android:id="@+id/key_v" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_key" android:text="v" android:textColor="@color/key_text" android:textSize="18sp" android:textAllCaps="false" />
                <View
                    android:id="@+id/keyboard_row_3_split_gap"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:visibility="gone" />
                <Button android:id="@+id/key_b" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_key" android:text="b" android:textColor="@color/key_text" android:textSize="18sp" android:textAllCaps="false" />
                <Button android:id="@+id/key_n" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_key" android:text="n" android:textColor="@color/key_text" android:textSize="18sp" android:textAllCaps="false" />
                <Button android:id="@+id/key_m" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_key" android:text="m" android:textColor="@color/key_text" android:textSize="18sp" android:textAllCaps="false" />

                <Button
                    android:id="@+id/key_backspace"
                    android:layout_width="62dp"
                    android:layout_height="match_parent"
                    android:layout_margin="2dp"
                    android:background="@drawable/bg_key_special"
                    android:text="⌫"
                    android:textAllCaps="false"
                    android:textColor="@color/key_text"
                    android:textSize="18sp"
                    android:contentDescription="@string/key_backspace" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/keyboard_row_4"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:layout_marginTop="2dp">

                <Button
                    android:id="@+id/key_layout_toggle"
                    android:layout_width="62dp"
                    android:layout_height="match_parent"
                    android:layout_margin="2dp"
                    android:background="@drawable/bg_key_special"
                    android:text="@string/key_toggle_symbols"
                    android:textAllCaps="false"
                    android:textColor="@color/key_text"
                    android:textSize="14sp"
                    android:contentDescription="@string/key_toggle_symbols" />

                <Button
                    android:id="@+id/key_language_toggle"
                    android:layout_width="56dp"
                    android:layout_height="match_parent"
                    android:layout_margin="2dp"
                    android:background="@drawable/bg_key_special"
                    android:text="@string/key_language_toggle"
                    android:textAllCaps="false"
                    android:textColor="@color/key_text"
                    android:textSize="14sp"
                    android:contentDescription="@string/key_language_toggle" />

                <Button
                    android:id="@+id/key_comma"
                    android:layout_width="48dp"
                    android:layout_height="match_parent"
                    android:layout_margin="2dp"
                    android:background="@drawable/bg_key"
                    android:text=","
                    android:textAllCaps="false"
                    android:textColor="@color/key_text"
                    android:textSize="16sp"
                    android:contentDescription="@string/key_comma" />

                <Button
                    android:id="@+id/key_space"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_margin="2dp"
                    android:background="@drawable/bg_key"
                    android:text="@string/key_space"
                    android:textAllCaps="false"
                    android:textColor="@color/key_text"
                    android:textSize="16sp"
                    android:contentDescription="@string/key_space" />

                <View
                    android:id="@+id/keyboard_row_4_split_gap"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/key_space_right"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="0"
                    android:layout_margin="2dp"
                    android:background="@drawable/bg_key"
                    android:text="@string/key_space"
                    android:textAllCaps="false"
                    android:textColor="@color/key_text"
                    android:textSize="16sp"
                    android:contentDescription="@string/key_space"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/key_period"
                    android:layout_width="48dp"
                    android:layout_height="match_parent"
                    android:layout_margin="2dp"
                    android:background="@drawable/bg_key"
                    android:text="."
                    android:textAllCaps="false"
                    android:textColor="@color/key_text"
                    android:textSize="16sp"
                    android:contentDescription="@string/key_period" />

                <Button
                    android:id="@+id/key_enter"
                    android:layout_width="62dp"
                    android:layout_height="match_parent"
                    android:layout_margin="2dp"
                    android:background="@drawable/bg_key_special"
                    android:text="@string/key_enter_default"
                    android:textAllCaps="false"
                    android:textColor="@color/key_text"
                    android:textSize="15sp"
                    android:contentDescription="@string/key_enter_default" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/panel_handwriting"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:padding="8dp">

            <com.directwriting.ime.CanvasView
                android:id="@+id/canvas_view"
                android:layout_width="match_parent"
                android:layout_height="230dp"
                android:background="@drawable/canvas_background" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="4dp">

                <Button
                    android:id="@+id/btn_mode_toggle_handwriting"
                    android:layout_width="62dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_key_special"
                    android:text="@string/mode_keyboard"
                    android:textAllCaps="false"
                    android:textColor="@color/key_text"
                    android:textSize="13sp"
                    android:contentDescription="@string/btn_mode_toggle"
                    android:layout_marginEnd="6dp" />

                <Button
                    android:id="@+id/btn_pen_tool"
                    android:layout_width="52dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_handwriting_tool_toggle"
                    android:text="@string/btn_pen_tool"
                    android:textAllCaps="false"
                    android:textColor="@color/key_text"
                    android:textSize="13sp"
                    android:contentDescription="@string/btn_pen_tool" />

                <Button
                    android:id="@+id/btn_eraser_tool"
                    android:layout_width="62dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_handwriting_tool_toggle"
                    android:text="@string/btn_eraser_tool"
                    android:textAllCaps="false"
                    android:textColor="@color/key_text"
                    android:textSize="13sp"
                    android:contentDescription="@string/btn_eraser_tool" />

                <ImageButton
                    android:id="@+id/btn_undo"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_undo"
                    android:background="@drawable/bg_key_special"
                    android:contentDescription="@string/btn_undo"
                    android:tint="@color/icon_tint"
                    android:scaleType="centerInside"
                    android:padding="10dp"
                    android:layout_marginEnd="6dp" />

                <ImageButton
                    android:id="@+id/btn_redo"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_redo"
                    android:background="@drawable/bg_key_special"
                    android:contentDescription="@string/btn_redo"
                    android:tint="@color/icon_tint"
                    android:scaleType="centerInside"
                    android:padding="10dp"
                    android:layout_marginEnd="6dp" />

                <ImageButton
                    android:id="@+id/btn_clear"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_clear"
                    android:background="@drawable/bg_key_special"
                    android:contentDescription="@string/btn_clear"
                    android:tint="@color/icon_tint"
                    android:scaleType="centerInside"
                    android:padding="10dp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <ImageButton
                    android:id="@+id/btn_send"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_send"
                    android:background="@drawable/btn_send_background"
                    android:contentDescription="@string/btn_send"
                    android:tint="@android:color/white"
                    android:scaleType="centerInside"
                    android:padding="12dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/handwriting_tool_settings_panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_quickbar_chip"
                android:orientation="vertical"
                android:padding="10dp"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/panel_pen_settings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/handwriting_pen_settings"
                        android:textColor="@color/key_text"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/handwriting_pen_thickness"
                            android:textColor="@color/key_text"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tv_pen_thickness_value"
                            android:layout_width="36dp"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:text="4"
                            android:textColor="@color/key_text"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <SeekBar
                        android:id="@+id/seek_pen_thickness"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="19"
                        android:progress="3"
                        android:progressTint="@color/primary"
                        android:thumbTint="@color/primary" />

                    <Switch
                        android:id="@+id/switch_pen_pressure"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:checked="true"
                        android:text="@string/handwriting_pressure_sensitivity"
                        android:textColor="@color/key_text"
                        android:textSize="13sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/handwriting_pen_color"
                        android:textColor="@color/key_text"
                        android:textSize="13sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <View
                            android:id="@+id/color_chip_0"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_marginEnd="6dp"
                            android:contentDescription="@string/color_black" />

                        <View
                            android:id="@+id/color_chip_1"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_marginEnd="6dp"
                            android:contentDescription="@string/color_red" />

                        <View
                            android:id="@+id/color_chip_2"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_marginEnd="6dp"
                            android:contentDescription="@string/color_orange" />

                        <View
                            android:id="@+id/color_chip_3"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_marginEnd="6dp"
                            android:contentDescription="@string/color_yellow" />

                        <View
                            android:id="@+id/color_chip_4"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_marginEnd="6dp"
                            android:contentDescription="@string/color_teal" />

                        <View
                            android:id="@+id/color_chip_5"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_marginEnd="6dp"
                            android:contentDescription="@string/color_blue" />

                        <View
                            android:id="@+id/color_chip_6"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_marginEnd="6dp"
                            android:contentDescription="@string/color_indigo" />

                        <View
                            android:id="@+id/color_chip_7"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:contentDescription="@string/color_purple" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/panel_eraser_settings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/handwriting_eraser_settings"
                        android:textColor="@color/key_text"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/handwriting_eraser_mode"
                        android:textColor="@color/key_text"
                        android:textSize="13sp" />

                    <RadioGroup
                        android:id="@+id/group_eraser_mode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:orientation="horizontal">

                        <RadioButton
                            android:id="@+id/radio_eraser_stroke"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/handwriting_eraser_mode_stroke"
                            android:textColor="@color/key_text"
                            android:textSize="13sp" />

                        <RadioButton
                            android:id="@+id/radio_eraser_area"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="@string/handwriting_eraser_mode_area"
                            android:textColor="@color/key_text"
                            android:textSize="13sp" />
                    </RadioGroup>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/handwriting_eraser_size"
                            android:textColor="@color/key_text"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tv_eraser_size_value"
                            android:layout_width="48dp"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:text="24px"
                            android:textColor="@color/key_text"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <SeekBar
                        android:id="@+id/seek_eraser_size"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="64"
                        android:progress="16"
                        android:progressTint="@color/primary"
                        android:thumbTint="@color/primary" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
